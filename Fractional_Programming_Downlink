    "#import libraries\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import tensorflow.compat.v1 as tf\n",
    "import time\n",
    "from tqdm import tqdm\n",
    "\n",
    "tf.disable_eager_execution()\n",
    "tf.reset_default_graph()\n",
    "\n",
    "#define variables\n",
    "no_of_users = 4\n",
    "no_of_antennas = 4\n",
    "scheduled_users = [0,1,2,3]\n",
    "epsilon = 0.0001\n",
    "power_tolerance = 0.0001\n",
    "total_power = 10\n",
    "noise_power = 1\n",
    "no_of_iterations_nn= 6\n",
    "no_of_iterations = 6\n",
    "no_of_samples_per_batch = 100\n",
    "no_of_batches_training = 5000\n",
    "no_of_batches_testing = 1000\n",
    "user_weights_tf = np.reshape(np.ones(no_of_samples_per_batch*no_of_users),(no_of_samples_per_batch,no_of_users,1))\n",
    "user_weights = tf.constant(user_weights_tf, dtype=tf.float64)\n",
    "user_weights_classical= np.ones(no_of_users)\n",
    "\n",
    "# compute channel\n",
    "def compute_channel(no_of_users,no_of_antennas,total_power,path_loss_option = False,path_loss_range = [-5,5]):\n",
    "  channel_input = []\n",
    "  initial_transmitter_precoder= []\n",
    "  channel_WMMSE = np.zeros((no_of_users, no_of_antennas)) + 1j*np.zeros((no_of_users, no_of_antennas))\n",
    "  for user in range(no_of_users):\n",
    "    path_loss =0\n",
    "    if path_loss_option == True:\n",
    "      path_loss = np.random.uniform(path_loss_range[0],path_loss_range[-1])\n",
    "    realpart_h = np.sqrt(10**(path_loss/10))*np.sqrt(0.5)*np.random.normal(size = (no_of_antennas,1))\n",
    "    imagpart_h = np.sqrt(10**(path_loss/10))*np.sqrt(0.5)*np.random.normal(size = (no_of_antennas,1))\n",
    "    channel_WMMSE[user,:] = np.reshape(realpart_h,(1,no_of_antennas)) + 1j*np.reshape(imagpart_h, (1,no_of_antennas))\n",
    "    h_col1 = np.vstack((realpart_h,imagpart_h))\n",
    "    h_col2 = np.vstack((-imagpart_h,realpart_h))\n",
    "    h = np.hstack((h_col1,h_col2))\n",
    "    channel_input.append(h)\n",
    "    initial_transmitter_precoder.append(h_col1)\n",
    "  initial_transmitter_precoder_temp = np.array(initial_transmitter_precoder)\n",
    "  norm_v = np.linalg.norm(initial_transmitter_precoder_temp)\n",
    "  initial_transmitter_precoder_temp = initial_transmitter_precoder_temp*np.sqrt(total_power)/norm_v\n",
    "  initial_transmitter_precoder = []\n",
    "\n",
    "  for user in range(no_of_users):\n",
    "    initial_transmitter_precoder.append(initial_transmitter_precoder_temp[user])\n",
    "  return channel_input,initial_transmitter_precoder,channel_WMMSE\n",
    "\n",
    "#helper functions\n",
    "# compute S and I\n",
    "def compute_s_i(user_i,initial_transmitter_precoder,channel_input,noise_power,no_of_users):\n",
    "  numerator = tf.reduce_sum(tf.matmul(tf.transpose(channel_input[user_i][:, 0:1]),initial_transmitter_precoder[user_i]) ** 2)\n",
    "  inter_interference = 0\n",
    "  for user_j in range(no_of_users):\n",
    "    if user_j != user_i:\n",
    "      inter_interference += tf.reduce_sum(tf.matmul(tf.transpose(channel_input[user_i][:, 0:1]),initial_transmitter_precoder[user_j]) ** 2)\n",
    "  denominator = inter_interference + noise_power\n",
    "  return numerator,denominator\n",
    "\n",
    "def compute_SINR_terms(channel, precoder, noise_power):\n",
    "    no_of_users = np.size(channel, 0)\n",
    "    S = np.zeros(no_of_users)\n",
    "    I = np.zeros(no_of_users)\n",
    "    for user_id in range(no_of_users):\n",
    "        # Signal\n",
    "        numerator = np.abs( np.matmul(np.conj(channel[user_id, :]),precoder[user_id, :] ))**2\n",
    "        # Interference\n",
    "        inter_user_interference = 0\n",
    "        for user_index in range(no_of_users):\n",
    "            if user_index != user_id:\n",
    "                inter_user_interference += np.abs(np.matmul(np.conj(channel[user_id, :]),precoder[user_index, :]))**2\n",
    "        denominator = noise_power + inter_user_interference\n",
    "        S[user_id] = numerator.real\n",
    "        I[user_id] = denominator.real\n",
    "    return S, I\n",
    "def compute_metrics(H, V, noise_power, user_weights):\n",
    "    S, I = compute_SINR_terms(H, V, noise_power)\n",
    "    SINR = S / I\n",
    "    # Surrogate WSR\n",
    "    g = SINR\n",
    "    u = np.sqrt(user_weights.flatten() * (1 + g) * S) / (S + I)\n",
    "    surrogate = np.sum(2*u*np.sqrt(user_weights.flatten()*(1+g)*S) - u**2*(S+I)) + np.sum((np.log2(1+g))*user_weights.flatten()) - np.sum(g*user_weights.flatten())\n",
    "    return surrogate.real\n",
    "def compute_sinr(user_i,initial_transmitter_precoder,channel_input,noise_power,no_of_users):\n",
    "  numerator = tf.reduce_sum(tf.matmul(tf.transpose(channel_input[user_i]),initial_transmitter_precoder[user_i]) ** 2)\n",
    "  inter_interference = 0\n",
    "  for user_j in range(no_of_users):\n",
    "    if user_j != user_i:\n",
    "      inter_interference += tf.reduce_sum(tf.matmul(tf.transpose(channel_input[user_i]),initial_transmitter_precoder[user_j]) ** 2)\n",
    "  denominator = inter_interference + noise_power\n",
    "\n",
    "  sinr_user = numerator/denominator\n",
    "  return sinr_user\n",
    "def compute_wsr_nn(user_weights,initial_transmitter_precoder,channel_input,total_power):\n",
    "  wsr = 0\n",
    "  for sample in range(no_of_samples_per_batch):\n",
    "    for user_i in range(no_of_users):\n",
    "      sinr = compute_sinr(user_i,initial_transmitter_precoder[sample],channel_input[sample],noise_power,no_of_users)\n",
    "      wsr += user_weights[sample][user_i] * (tf.log(1 + sinr)/tf.log(tf.cast(2.0,tf.float64)))\n",
    "  return wsr\n",
    "\n",
    "def optimal_g_u_fixed(final_precoder_in,channel_input_in):\n",
    "  g_val = []\n",
    "  u_val = []\n",
    "  for sample in range(no_of_samples_per_batch):\n",
    "    g_sample = []\n",
    "    u_sample = []\n",
    "    for user_i in range(no_of_users):\n",
    "      S,I = compute_s_i(user_i,final_precoder_in[sample],channel_input_in[sample],noise_power,no_of_users)\n",
    "      g = S/I\n",
    "      # Corrected access to user_weights for scalar value\n",
    "      u = tf.sqrt(user_weights[sample,user_i,0] * (1 + g) * S) / (S + I)\n",
    "      g_sample.append(g)\n",
    "      u_sample.append(u)\n",
    "    g_val.append(tf.stack(g_sample))\n",
    "    u_val.append(tf.stack(u_sample))\n",
    "  return tf.stack(g_val), tf.stack(u_val)\n",
    "\n",
    "\n",
    "def compute_func_fixed(user_weights_in,u_in,g_in,initial_transmitter_precoder_in,channel_input_in,total_power_in):\n",
    "  RQ = 0\n",
    "  for sample in range(no_of_samples_per_batch):\n",
    "    for user_i in range(no_of_users):\n",
    "      S,I = compute_s_i(user_i,initial_transmitter_precoder_in[sample],channel_input_in[sample],noise_power,no_of_users)\n",
    "      # Corrected access to user_weights for scalar value\n",
    "      term = 2*u_in[sample,user_i]*tf.sqrt(user_weights_in[sample,user_i,0]*(1+g_in[sample,user_i])*S) - u_in[sample,user_i]**2*(S+I) + (user_weights_in[sample,user_i,0] * (tf.math.log(1 + g_in[sample, user_i]) / tf.math.log(tf.cast(2.0, tf.float64)))) - (user_weights_in[sample,user_i,0] * g_in[sample, user_i])\n",
    "      RQ+=term\n",
    "  return RQ\n",
    "def pgd_step(init, name, user_weights, g, u,channel, initial_transmitter_precoder, total_power):\n",
    "    with tf.variable_scope(name):\n",
    "        # Learnable step size\n",
    "        step_size = tf.Variable(tf.constant(init, dtype=tf.float64), name='step_size')\n",
    "        # Shapes:\n",
    "        # channel: [batch, users, 2N, 2N]\n",
    "        # precoder: [batch, users, 2N, 1]\n",
    "        hi = channel[:, :, :, 0:1]   # [B, K, 2N, 1]\n",
    "        vk = initial_transmitter_precoder  # [B, K, 2N, 1]\n",
    "\n",
    "        h_hT = tf.matmul(hi, hi, adjoint_b=True)   # [B, K, 2N, 2N]\n",
    "        \n",
    "        u_sq = tf.reshape(u**2, [no_of_samples_per_batch, no_of_users,1, 1])\n",
    "        \n",
    "        A = tf.reduce_sum(u_sq * h_hT, axis=1, keepdims=True)  # [B, 1, 2N, 2N]\n",
    "        # Linear term\n",
    "        wk = user_weights                         # [B, K, 1]\n",
    "        gk = tf.reshape(g, [no_of_samples_per_batch,no_of_users, 1])\n",
    "        uk = tf.reshape(u, [no_of_samples_per_batch, no_of_users, 1])\n",
    "        coeff = 2.0 * uk * tf.sqrt(wk * (1.0 + gk))  # [B, K, 1]\n",
    "        linear_term = coeff[:, :, :, None] * hi      # [B, K, 2N, 1]\n",
    "        # Quadratic term\n",
    "        quad_term = 2.0 * tf.matmul(A, vk)  \n",
    "        # Gradient\n",
    "        gradient = linear_term - quad_term\n",
    "        # PGD update\n",
    "        output_temp = vk + step_size * gradient\n",
    "        # Power Projection\n",
    "        sample_power = tf.reduce_sum( tf.square(output_temp), axis=[1, 2, 3], keepdims=True )\n",
    "        scale = tf.sqrt(total_power /tf.maximum(sample_power, total_power) )\n",
    "        output = output_temp * tf.cast(scale, tf.float64)\n",
    "    return output, step_size\n"
   ]
