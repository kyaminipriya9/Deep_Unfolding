    "def run_classical_FP(epsilon,channel,selected_users,total_power,noise_power,user_weights,max_no_of_iterations,log=False):\n",
    "\n",
    "    K = channel.shape[0]\n",
    "    M = channel.shape[1]\n",
    "\n",
    "    user_weights = user_weights.flatten()\n",
    "    V = np.zeros((K, M), dtype=complex)\n",
    "    for k in selected_users:\n",
    "        V[k, :] = channel[k, :]\n",
    "    V = V / np.linalg.norm(V) * np.sqrt(total_power)\n",
    "    WSR_surrogate_list = []\n",
    "    # Initial metrics\n",
    "    surrogate = compute_metrics(channel, V, noise_power, user_weights)\n",
    "\n",
    "    WSR_surrogate_list.append(surrogate)\n",
    "    iteration_counter = 0\n",
    "    diff = epsilon + 1\n",
    "    while diff >= epsilon and iteration_counter <= max_no_of_iterations:\n",
    "        iteration_counter += 1\n",
    "        S, I = compute_SINR_terms(channel, V, noise_power)\n",
    "        g = S / I\n",
    "        u = np.sqrt(user_weights * (1 + g) * S) / (S + I)\n",
    "        A = np.zeros((M, M), dtype=complex)\n",
    "        for k in selected_users:\n",
    "            h = channel[k, :].reshape(-1, 1)\n",
    "            A += (u[k]**2) * (h @ h.conj().T)\n",
    "        Sigma_diag_elements, U = np.linalg.eigh(A)\n",
    "        Sigma_diag_elements = np.real(Sigma_diag_elements)\n",
    "        Lambda = np.zeros((M, M), dtype=complex)\n",
    "        for k in selected_users:\n",
    "            h = channel[k, :].reshape(-1, 1)\n",
    "            Lambda += (user_weights[k] * (1 + g[k]) * (u[k]**2)) * (h @ h.conj().T)\n",
    "\n",
    "        Phi = U.conj().T @ Lambda @ U\n",
    "        Phi_diag_elements = np.real(np.diag(Phi))\n",
    "        def compute_power_FP(nu):\n",
    "            return np.sum(\n",
    "                Phi_diag_elements / (Sigma_diag_elements + nu)**2\n",
    "            )\n",
    "        nu_low = 0.0\n",
    "        nu_high = np.sqrt(np.sum(Phi_diag_elements) / total_power + 1e-12)\n",
    "\n",
    "        for _ in range(100):\n",
    "            nu_mid = (nu_low + nu_high) / 2\n",
    "            power = compute_power_FP(nu_mid)\n",
    "\n",
    "            if power > total_power:\n",
    "                nu_low = nu_mid\n",
    "            else:\n",
    "                nu_high = nu_mid\n",
    "\n",
    "        nu_star = nu_high\n",
    "\n",
    "        inv_term = np.linalg.inv(A + nu_star * np.eye(M))\n",
    "\n",
    "        for k in selected_users:\n",
    "            h = channel[k, :].reshape(-1, 1)\n",
    "            coeff = np.sqrt(user_weights[k] * (1 + g[k])) * u[k]\n",
    "            V[k, :] = (coeff * (inv_term @ h)).flatten()\n",
    "        surrogate_new = compute_metrics(channel, V, noise_power, user_weights)\n",
    "        WSR_surrogate_list.append(surrogate_new)\n",
    "\n",
    "        diff = abs(surrogate_new - WSR_surrogate_list[-2])\n",
    "\n",
    "    return V,WSR_surrogate_list[-1],WSR_surrogate_list"
   ]
